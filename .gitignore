*.onnx
*.tflite
*.pt
*.bin

# Generated calibration data
calibration_dataset/

# Keep model directory skeleton, ignore binary model artifacts
examples/**/model/**/*.tflite
examples/**/model/**/*.dla
examples/**/model/**/*.bin
examples/**/model/**/*.onnx

# Keep placeholder files inside model folders
!examples/**/model/fp32/.gitkeep
!examples/**/model/int8/.gitkeep
