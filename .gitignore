# Build artifacts
build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json

# Runtime outputs
outputs/

# Editors / IDE
.cursor/
.vscode/
.idea/

# OS junk
.DS_Store
Thumbs.db

# Logs and temp
*.log
*.tmp
*.swp

# Python cache
__pycache__/
*.py[cod]

# Virtual env and local env files
.venv/
venv/
.env

# Tooling cache
.ruff_cache/
.pytest_cache/
*.cache

